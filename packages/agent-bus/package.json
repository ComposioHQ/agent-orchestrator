{
  "name": "@composio/ao-agent-bus",
  "version": "0.1.0",
  "description": "Filesystem message bus and agent toolkit for ao-teams",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ao-bus-cli": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "ao-bus.sh",
    "ao-bus.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ComposioHQ/agent-orchestrator.git",
    "directory": "packages/agent-bus"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@composio/ao-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
