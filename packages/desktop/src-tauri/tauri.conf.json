{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Orchestrator Desktop",
  "version": "0.1.0",
  "identifier": "io.composio.agentorchestrator.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @composio/ao-desktop dev",
    "beforeBuildCommand": "pnpm --filter @composio/ao-desktop build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Orchestrator Desktop",
        "width": 1280,
        "height": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
