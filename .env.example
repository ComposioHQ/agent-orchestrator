# Agent Orchestrator environment variables
# Copy this to `.env` (or export in your shell) and fill values as needed.

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# Optional: force config file path instead of auto-discovery
AO_CONFIG_PATH=./agent-orchestrator.yaml

# -----------------------------------------------------------------------------
# Dashboard / terminal servers
# -----------------------------------------------------------------------------

# Main web dashboard port
PORT=3000

# Terminal bridge ports (used by web terminal services)
TERMINAL_PORT=14800
DIRECT_TERMINAL_PORT=14801

# Optional client overrides when running web directly
NEXT_PUBLIC_TERMINAL_PORT=14800
NEXT_PUBLIC_DIRECT_TERMINAL_PORT=14801

# -----------------------------------------------------------------------------
# GitHub CLI / SCM
# -----------------------------------------------------------------------------

# Optional tokens for gh CLI environments (if your shell requires them)
GITHUB_TOKEN=
GH_TOKEN=

# -----------------------------------------------------------------------------
# Linear tracker
# -----------------------------------------------------------------------------

LINEAR_API_KEY=

# Optional: used in integration test/example flows
LINEAR_TEAM_ID=

# -----------------------------------------------------------------------------
# z.ai (GLM) via `agent: zai`
# -----------------------------------------------------------------------------

# Recommended auth token variable
ZAI_API_KEY=

# Optional z.ai Anthropic-compatible endpoint override
ZAI_ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# Optional fallback token for Anthropic-compatible clients
ANTHROPIC_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Other model providers (optional, depends on your agent setup)
# -----------------------------------------------------------------------------

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Composio notifications / transport
# -----------------------------------------------------------------------------

COMPOSIO_API_KEY=
COMPOSIO_ENTITY_ID=default

# -----------------------------------------------------------------------------
# Optional notifier convenience values
# -----------------------------------------------------------------------------

SLACK_WEBHOOK_URL=
